{
  "name": "treeselectjs-monorepo",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "check": "pnpm -r check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "clear-dist": "node .script/removeDist.js",
    "clear-all": "node .script/removeDist.js && node .script/removeNodeModules.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0"
  }
}
